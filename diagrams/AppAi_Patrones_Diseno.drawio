        <mxCell id="L3_uc" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=11;align=center;" value="&lt;b&gt;Use Cases&lt;/b&gt;&lt;br/&gt;— Auth: AuthenticateUser · RefreshToken&lt;br/&gt;ChangePassword · RequestPasswordReset · ResetPassword&lt;br/&gt;— Users: CreateUser · UpdateUser · DeleteUser&lt;br/&gt;ListUsers · UpdateProfilePhoto&lt;br/&gt;— Chat: SendPromptToAI · StreamChatUseCase&lt;br/&gt;ListConversations · DeleteConversation&lt;br/&gt;— Documents: UploadDocument · ListDocuments&lt;br/&gt;DeleteDocument · DownloadDocument&lt;br/&gt;— AI: ProcessDocumentForAI · AskAIQuestion&lt;br/&gt;&lt;br/&gt;&lt;i&gt;&lt;font color=&#39;#1a6600&#39;&gt;[Use Case / Command Pattern — SRP]&lt;/font&gt;&lt;/i&gt;" vertex="1">
          <mxGeometry height="145" width="390" x="55" y="545" as="geometry" />
        </mxCell>
        <mxCell id="L3_dto" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=11;align=center;" value="&lt;b&gt;DTOs&lt;/b&gt;&lt;br/&gt;AuthDTO&lt;br/&gt;ChatDTO&lt;br/&gt;DocumentDTO&lt;br/&gt;UserDTO&lt;br/&gt;Objetos de transferencia&lt;br/&gt;entre capas HTTP e interna.&lt;br/&gt;&lt;br/&gt;&lt;i&gt;&lt;font color=&#39;#1a6600&#39;&gt;[Data Transfer Object Pattern]&lt;/font&gt;&lt;/i&gt;" vertex="1">
          <mxGeometry height="145" width="250" x="465" y="545" as="geometry" />
        </mxCell>
        <mxCell id="L3_rbac" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=11;align=center;" value="&lt;b&gt;RBAC — permissions.ts&lt;/b&gt;&lt;br/&gt;Roles: ADMIN · GESTOR&lt;br/&gt;INSTRUCTOR · EMPLEADO&lt;br/&gt;&lt;br/&gt;Permisos: CREATE_USER&lt;br/&gt;UPLOAD_DOCUMENT · LIST_DOCUMENTS&lt;br/&gt;DELETE_DOCUMENT · CHAT_ACCESS&lt;br/&gt;&lt;br/&gt;&lt;i&gt;&lt;font color=&#39;#1a6600&#39;&gt;[Role-Based Access Control]&lt;/font&gt;&lt;/i&gt;" vertex="1">
          <mxGeometry height="145" width="280" x="735" y="545" as="geometry" />
        </mxCell>
        <mxCell id="L3_gr" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#82b366;fontSize=11;align=center;" value="&lt;b&gt;Guardrails ★&lt;/b&gt;&lt;br/&gt;InputGuardrail&lt;br/&gt;→ Valida pregunta ANTES del LLM&lt;br/&gt;→ Bloquea prompt injection&lt;br/&gt;&lt;br/&gt;OutputGuardrail&lt;br/&gt;→ Valida respuesta DESPUÉS del LLM&lt;br/&gt;→ Detecta escape de rol / conocimiento externo&lt;br/&gt;&lt;br/&gt;&lt;i&gt;&lt;font color=&#39;#1a6600&#39;&gt;[Guardrail Pattern]&lt;/font&gt;&lt;/i&gt;" vertex="1">
          <mxGeometry height="145" width="310" x="1035" y="545" as="geometry" />
        </mxCell>
        <mxCell id="L4_bg" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;verticalAlign=top;fontSize=13;fontStyle=1;arcSize=2;" value="DOMAIN — Núcleo puro (sin dependencias externas: cero imports de Fastify, Prisma, LangChain)" vertex="1">
          <mxGeometry height="190" width="1600" x="35" y="730" as="geometry" />
        </mxCell>
        <mxCell id="L4_ent" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=11;align=center;" value="&lt;b&gt;Entities&lt;/b&gt;&lt;br/&gt;User · Document · Conversation&lt;br/&gt;Prompt · AIResponse · DocumentChunk&lt;br/&gt;&lt;br/&gt;Lógica de negocio pura.&lt;br/&gt;No dependen de ningún framework.&lt;br/&gt;&lt;br/&gt;&lt;i&gt;&lt;font color=&#39;#5c0080&#39;&gt;[Entity Pattern]&lt;/font&gt;&lt;/i&gt;" vertex="1">
          <mxGeometry height="128" width="350" x="55" y="773" as="geometry" />
        </mxCell>
        <mxCell id="L4_repo" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=11;align=center;" value="&lt;b&gt;Repository Interfaces (contratos)&lt;/b&gt;&lt;br/&gt;UserRepository&lt;br/&gt;DocumentRepository&lt;br/&gt;ConversationRepository&lt;br/&gt;VectorRepository&lt;br/&gt;&lt;br/&gt;Definidas en Domain, implementadas en Infrastructure.&lt;br/&gt;&lt;br/&gt;&lt;i&gt;&lt;font color=&#39;#5c0080&#39;&gt;[Repository Pattern — Contratos]&lt;/font&gt;&lt;/i&gt;" vertex="1">
          <mxGeometry height="128" width="380" x="425" y="773" as="geometry" />
        </mxCell>
        <mxCell id="L4_svc" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=11;align=center;" value="&lt;b&gt;Service Interfaces (contratos)&lt;/b&gt;&lt;br/&gt;AuthProvider&lt;br/&gt;AIProvider&lt;br/&gt;EmbeddingService · ChunkingService&lt;br/&gt;VectorSearchService · AIService&lt;br/&gt;&lt;br/&gt;Permiten sustituir proveedores&lt;br/&gt;(ej. Gemini → OpenAI) sin tocar el core.&lt;br/&gt;&lt;br/&gt;&lt;i&gt;&lt;font color=&#39;#5c0080&#39;&gt;[Strategy Pattern — Contratos]&lt;/font&gt;&lt;/i&gt;" vertex="1">
          <mxGeometry height="128" width="380" x="825" y="773" as="geometry" />
        </mxCell>
        <mxCell id="ai_module" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=center;" value="&lt;b&gt;Módulo AI (auto-contenido)&lt;/b&gt;&lt;br/&gt;modules/ai/ replica internamente&lt;br/&gt;las 4 capas de Clean Architecture.&lt;br/&gt;Diseñado para sustituir Gemini&lt;br/&gt;por otro proveedor sin tocar el core.&lt;br/&gt;&lt;br/&gt;&lt;i&gt;[Bounded Context / Plugin Pattern]&lt;/i&gt;" vertex="1">
          <mxGeometry height="155" width="270" x="1355" y="545" as="geometry" />
        </mxCell>
        <mxCell id="legend_bg" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" value="" vertex="1">
          <mxGeometry height="110" width="1600" x="35" y="940" as="geometry" />
        </mxCell>
        <mxCell id="legend_title" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1;" value="&lt;b&gt;RESUMEN DE PATRONES APLICADOS&lt;/b&gt;" vertex="1">
          <mxGeometry height="25" width="400" x="55" y="948" as="geometry" />
        </mxCell>
        <mxCell id="legend_col1" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;" value="&lt;b&gt;Clean Architecture&lt;/b&gt; — patrón arquitectural macro. 4 capas con dependencias hacia adentro.&lt;br/&gt;&lt;b&gt;Repository Pattern&lt;/b&gt; — interfaz en Domain, implementación en Infrastructure. Desacopla BD.&lt;br/&gt;&lt;b&gt;Use Case / Command Pattern&lt;/b&gt; — un archivo = un caso de uso. Principio de Responsabilidad Única (SRP)." vertex="1">
          <mxGeometry height="70" width="490" x="55" y="975" as="geometry" />
        </mxCell>
        <mxCell id="legend_col2" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;" value="&lt;b&gt;Strategy Pattern&lt;/b&gt; — interfaces en Domain, implementaciones intercambiables en Infrastructure.&lt;br/&gt;&lt;b&gt;Provider Pattern&lt;/b&gt; — DatabaseAuthProvider implementa AuthProvider. Extensible a OAuth/Keycloak.&lt;br/&gt;&lt;b&gt;Dependency Injection (IoC Manual)&lt;/b&gt; — routes/index.ts hace el wiring completo al arrancar." vertex="1">
          <mxGeometry height="70" width="490" x="565" y="975" as="geometry" />
        </mxCell>
        <mxCell id="legend_col3" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;" value="&lt;b&gt;Middleware / Chain of Responsibility&lt;/b&gt; — AuthMiddleware → RoleGuard → Controller en cadena.&lt;br/&gt;&lt;b&gt;Observer Pattern ★&lt;/b&gt; — LLMCallbackHandler observa el ciclo de vida del LLM sin modificarlo.&lt;br/&gt;&lt;b&gt;Guardrail Pattern ★&lt;/b&gt; — InputGuardrail + OutputGuardrail filtran entrada y salida del LLM.&lt;br/&gt;&lt;b&gt;Rotating Refresh Token ★★&lt;/b&gt; — Par JWT (1d) + RefreshToken (7d) rotativo. Auto-refresh con promesa compartida en apiClient.ts.&lt;br/&gt;&lt;b&gt;SSE Streaming ★★&lt;/b&gt; — AsyncGenerator en GeminiAIService. reply.hijack() para eludir hook onSend de CORS.&lt;br/&gt;&lt;i&gt;★ = sesión 2026-04-16 · ★★ = sesión 2026-04-27&lt;/i&gt;" vertex="1">
          <mxGeometry height="70" width="540" x="1065" y="950" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
