        <mxCell id="L2_cb" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=center;" value="&lt;b&gt;LLMCallbackHandler ★&lt;/b&gt;&lt;br/&gt;handleLLMStart → log inicio + prompt&lt;br/&gt;handleLLMEnd → latencia + tokens&lt;br/&gt;handleLLMError → log de errores&lt;br/&gt;Extiende BaseCallbackHandler&lt;br/&gt;&lt;br/&gt;&lt;i&gt;&lt;font color=&#39;#8a4500&#39;&gt;[Observer Pattern / Middleware]&lt;/font&gt;&lt;/i&gt;" vertex="1">
