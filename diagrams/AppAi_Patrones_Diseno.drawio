        <mxCell id="L2_sec" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=11;align=center;" value="&lt;b&gt;Security&lt;/b&gt;&lt;br/&gt;JwtService&lt;br/&gt;(sign / verify)&lt;br/&gt;&lt;br/&gt;PasswordHasher&lt;br/&gt;(bcrypt 10 rounds)&lt;br/&gt;&lt;br/&gt;&lt;i&gt;&lt;font color=&#39;#8a4500&#39;&gt;[Security Services]&lt;/font&gt;&lt;/i&gt;" vertex="1">
