        <mxCell id="L2_auth" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=11;align=center;" value="&lt;b&gt;DatabaseAuthProvider&lt;/b&gt;&lt;br/&gt;Implementa AuthProvider (Domain).&lt;br/&gt;Genera refresh token (64-char hex, 7d)&lt;br/&gt;al autenticar. Extensible a OAuth/Keycloak.&lt;br/&gt;&lt;br/&gt;&lt;b&gt;NodemailerEmailService&lt;/b&gt;&lt;br/&gt;Implementa IEmailService (Domain).&lt;br/&gt;Proveedor actual: Mailtrap SMTP sandbox.&lt;br/&gt;&lt;br/&gt;&lt;i&gt;&lt;font color=&#39;#8a4500&#39;&gt;[Provider Pattern]&lt;/font&gt;&lt;/i&gt;" vertex="1">
